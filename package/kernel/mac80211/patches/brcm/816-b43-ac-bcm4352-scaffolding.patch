 #define B43_PHY_AC_TABLE_OFFSET			0x00e
@@ -17,6 +68,77 @@
 #define  B43_PHY_AC_CLASSCTL_CCKEN		0x0001	/* CCK enable */
 #define  B43_PHY_AC_CLASSCTL_OFDMEN		0x0002	/* OFDM enable */

+	ENTRY(0x00000800, u16, pre, "pdoffset40ma1",      pdoffset40ma[1],      0, fb);
+	ENTRY(0x00000800, u16, pre, "pdoffset40ma2",      pdoffset40ma[2],      0, fb);
+	ENTRY(0x00000800, u16, pre, "pdoffset80ma0",      pdoffset80ma[0],      0, fb);

+/**************************************************
+ * R/W ops
+ **************************************************/
+
+/*
+ * Plain PHY register read/write.
+ *
+ * The 2015 stub only registered ->phy_maskset, which means b43_phy_read
+ * and b43_phy_write (called all over the rest of the b43 core) will
+ * dereference a NULL ->phy_read/->phy_write. Add them, identical in
+ * shape to phy_ht.c.
+ *
+ * The B43_WARN_ON(reg == 0xFFFF) gate is a defensive backstop for the
+ * register #defines that are intentionally commented out in phy_ac.h
+ * (currently B43_PHY_AC_TEST and B43_PHY_AC_RF_SEQ_MODE). If a future
+ * patch re-introduces them as 0xFFFF placeholders by mistake, or
+ * passes a literal 0xFFFF, this catches the access before it lands
+ * on a real register at that MMIO offset. Read returns 0 in the
+ * mistake path so the caller doesn't propagate undefined data; write
+ * is dropped silently after the warning. The b43_phy_read/write
+ * macros that wrap these helpers are uniform across the b43 core, so
+ * a single check here covers every PHY-side caller.
+ */
+static u16 b43_phy_ac_op_read(struct b43_wldev *dev, u16 reg)
+{
+	if (B43_WARN_ON(reg == 0xFFFF))
+		return 0;
+	b43_write16f(dev, B43_MMIO_PHY_CONTROL, reg);
+	return b43_read16(dev, B43_MMIO_PHY_DATA);
+}
+
+static void b43_phy_ac_op_write(struct b43_wldev *dev, u16 reg, u16 value)
+{
+	if (B43_WARN_ON(reg == 0xFFFF))
+		return;
+	b43_write16f(dev, B43_MMIO_PHY_CONTROL, reg);
+	b43_write16(dev, B43_MMIO_PHY_DATA, value);
+}

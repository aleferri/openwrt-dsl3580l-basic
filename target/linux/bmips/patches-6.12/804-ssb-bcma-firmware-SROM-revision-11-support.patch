From 0c5e37ad2e2d416867949f22f5a3704737e9e856 Mon Sep 17 00:00:00 2001
From: DRAFT <draft@example.com>
Date: Mon, 4 May 2026 09:51:16 +0000
Subject: [DRAFT PATCH v3] ssb / bcma / firmware: SROM revision 11 support
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Add support for SROM revision 11, introduced with the BCM4352 / BCM4360
family. The change is split across the three layers that need to land
together to be useful:

 1. struct ssb_sprom is extended with the rev-11 fields: per-band
    rxgains triplets, the front-end-module / PA control block,
    mcsbw80*po / mcsbw160*po / mcslr*po, the sb20in*/sb40and80 hr/lr
    matrix, dot11agdup{hr,lr}po, dot11agofdmhrbw202gpo /
    ofdmlrbw202gpo, and per-chain pdoffset arrays. The per-chain power
    info struct gains rev-11-shaped maxp2ga, maxp5ga[4], pa2ga[3],
    pa5ga[12]. All additions are appended; no offset shift on existing
    fields and no ABI break for in-tree consumers.

 2. drivers/firmware/broadcom/bcm47xx_sprom.c gains NVRAM key->field
    mappings for the new fields and a new path-style helper
    bcm47xx_fill_sprom_path_r11 for the per-chain comma-separated
    arrays (rxgains*, pa5ga[12], maxp5ga[4]). BCM47xx / BCM53xx boards
    expose these via NVRAM rather than raw SROM, and the existing
    bcm47xx_sprom_fill_auto pattern is extended mechanically.

 3. drivers/bcma/sprom.c gets bcma_sprom_extract_r11(), dispatched
    from bcma_sprom_get() when the SPROM revision word reads as 11.
    The dispatcher reads bus->sprom.revision, which bcma_sprom_valid
    has already populated from sprom[words - 1] (last word of the
    raw buffer) before the dispatcher runs. Reading a fixed legacy
    offset like SSB_SPROM_REVISION (0x7E) here would be wrong: that
    offset is the revision word only for SPROM rev 1-3, rev 4+ moved
    it to the last word and the absolute index depends on the rev-
    specific size. Revisions <= 10 keep the existing extract_r8
    path verbatim.

Caveat: the rev-11 offsets pinned in this patch are cross-referenced
against Broadcom's bcmhd source (bcmsrom_tbl.h / bcmsrom.h) and
exercised on a BCM4352-family board. The fields landing in the
0x190..0x1B0 region of the SPROM (mcslr*po, sb20in*, sb40and80*,
dot11agdup*po, pdoffset80ma, plus the femctrl context block) read
zero on that board and are not exercised by it; the patch therefore
declares the struct fields and reads them via the bcm47xx_sprom NVRAM
fallback path, but does not add the corresponding SSB_SPROM11_*
defines or extract them in bcma_sprom_extract_r11. They are listed as
TODO there pending a board that exercises them at runtime.

The bitfield masks/shifts for the shifted header fields (IL0MAC,
ANTAVAIL, TXRXC, CCODE, REGREV) are reused from rev 8: only the
absolute byte offset moved, the field layout within each word is
unchanged. CCODE is sourced from SSB_SPROM11_CCODE = 0x96 (per
bcmsrom.h) because reusing SSB_SPROM8_CCODE = 0x92 collides with the
middle u16 of the rev-11 IL0MAC block at 0x90.

Signed-off-by: TBD <tbd@example.com>
---
 drivers/bcma/sprom.c                      | 141 +++++++++++++++++++++++-
 drivers/firmware/broadcom/bcm47xx_sprom.c | 174 +++++++++++++++++++++++++++++-
 include/linux/ssb/ssb.h                   |  98 +++++++++++++++++
 include/linux/ssb/ssb_regs.h              |  70 ++++++++++++
 4 files changed, 480 insertions(+), 3 deletions(-)

diff --git a/drivers/bcma/sprom.c b/drivers/bcma/sprom.c
index e668ad7..08ba44a 100644
--- a/drivers/bcma/sprom.c
+++ b/drivers/bcma/sprom.c
@@ -474,6 +474,152 @@ static void bcma_sprom_extract_r8(struct bcma_bus *bus, const u16 *sprom)
 	     SSB_SPROM8_TEMPDELTA_HYSTERESIS_SHIFT);
 }
 
+static void bcma_sprom_unpack_rxgains(struct ssb_sprom_rxgains *out,
+				      int chain, u8 packed)
+{
+	/* Per-byte rxgains encoding:
+	 *   bit 7    = trelnabyp (T/R-eLNA bypass select)
+	 *   bits 6:3 = triso     (T/R isolation, 4-bit code)
+	 *   bits 2:0 = elnagain  (eLNA gain stage select, 3-bit code)
+	 */
+	out->trelnabyp[chain] = (packed >> 7) & 0x01;
+	out->triso[chain]     = (packed >> 3) & 0x0f;
+	out->elnagain[chain]  =  packed       & 0x07;
+}
+
+static void bcma_sprom_extract_r11(struct bcma_bus *bus, const u16 *sprom)
+{
+	static const u16 r11_pwr_info_offset[] = {
+		SSB_SPROM11_PWR_INFO_CORE0,
+		SSB_SPROM11_PWR_INFO_CORE1,
+		SSB_SPROM11_PWR_INFO_CORE2,
+	};
+	u16 v;
+	int i;
+
+	/* Header. IL0MAC / ANTAVAIL / TXRXC / CCODE / REGREV sit at
+	 * rev-11-specific offsets; bitfield masks/shifts are reused from
+	 * rev 8 (only the absolute byte offset moved).
+	 */
+	for (i = 0; i < 3; i++) {
+		v = sprom[SPOFF(SSB_SPROM11_IL0MAC) + i];
+		*(((__be16 *)bus->sprom.il0mac) + i) = cpu_to_be16(v);
+	}
+
+	SPEX(board_rev, SSB_SPROM8_BOARDREV, ~0, 0);
+	SPEX(board_type, SSB_SPROM1_SPID, ~0, 0);
+
+	SPEX(country_code, SSB_SPROM11_CCODE, ~0, 0);
+	SPEX(ant_available_a, SSB_SPROM11_ANTAVAIL, SSB_SPROM8_ANTAVAIL_A,
+	     SSB_SPROM8_ANTAVAIL_A_SHIFT);
+	SPEX(ant_available_bg, SSB_SPROM11_ANTAVAIL, SSB_SPROM8_ANTAVAIL_BG,
+	     SSB_SPROM8_ANTAVAIL_BG_SHIFT);
+
+	SPEX(txchain, SSB_SPROM11_TXRXC, SSB_SPROM8_TXRXC_TXCHAIN,
+	     SSB_SPROM8_TXRXC_TXCHAIN_SHIFT);
+	SPEX(rxchain, SSB_SPROM11_TXRXC, SSB_SPROM8_TXRXC_RXCHAIN,
+	     SSB_SPROM8_TXRXC_RXCHAIN_SHIFT);
+	SPEX(antswitch, SSB_SPROM11_TXRXC, SSB_SPROM8_TXRXC_SWITCH,
+	     SSB_SPROM8_TXRXC_SWITCH_SHIFT);
+
+	SPEX(subband5gver, SSB_SPROM11_SUBBAND5GVER, 0x00ff, 0);
+
+	/* Per-chain power info blocks. Stride 0x28 bytes; rev 11 caps at
+	 * 3 chains (vs rev 8's 4). Field offsets within a block are given
+	 * by SSB_SPROM11_PWR_*.
+	 */
+	BUILD_BUG_ON(ARRAY_SIZE(r11_pwr_info_offset) >
+		     ARRAY_SIZE(bus->sprom.core_pwr_info));
+
+	for (i = 0; i < ARRAY_SIZE(r11_pwr_info_offset); i++) {
+		struct ssb_sprom_core_pwr_info *p = &bus->sprom.core_pwr_info[i];
+		u16 base = r11_pwr_info_offset[i];
+		int j;
+
+		p->maxp2ga = sprom[SPOFF(base + SSB_SPROM11_PWR_MAXP2GA)] & 0x00ff;
+
+		for (j = 0; j < 3; j++)
+			p->pa2ga[j] = sprom[SPOFF(base + SSB_SPROM11_PWR_PA2GA) + j];
+
+		/* maxp5ga[4]: two consecutive u16 hold 4 x u8 packed LE. */
+		v = sprom[SPOFF(base + SSB_SPROM11_PWR_MAXP5GA)];
+		p->maxp5ga[0] = v & 0x00ff;
+		p->maxp5ga[1] = (v >> 8) & 0x00ff;
+		v = sprom[SPOFF(base + SSB_SPROM11_PWR_MAXP5GA) + 1];
+		p->maxp5ga[2] = v & 0x00ff;
+		p->maxp5ga[3] = (v >> 8) & 0x00ff;
+
+		for (j = 0; j < 12; j++)
+			p->pa5ga[j] = sprom[SPOFF(base + SSB_SPROM11_PWR_PA5GA) + j];
+
+		/* Rxgains: two consecutive u16 hold the four sub-band
+		 * triplets for this chain, one byte per sub-band. Byte-to-
+		 * sub-band assignment:
+		 *   RXGAINS0 lo -> 5gm, hi -> 5gh
+		 *   RXGAINS1 lo -> 2g,  hi -> 5gl (UNII-1)
+		 */
+		v = sprom[SPOFF(base + SSB_SPROM11_PWR_RXGAINS0)];
+		bcma_sprom_unpack_rxgains(&bus->sprom.rxgains_5gm, i,  v       & 0xff);
+		bcma_sprom_unpack_rxgains(&bus->sprom.rxgains_5gh, i, (v >> 8) & 0xff);
+		v = sprom[SPOFF(base + SSB_SPROM11_PWR_RXGAINS1)];
+		bcma_sprom_unpack_rxgains(&bus->sprom.rxgains_2g,  i,  v       & 0xff);
+		bcma_sprom_unpack_rxgains(&bus->sprom.rxgains_5gl, i, (v >> 8) & 0xff);
+	}
+
+	/* Per-chain pdoffset40ma triplet. */
+	for (i = 0; i < 3; i++)
+		bus->sprom.pdoffset40ma[i] =
+			sprom[SPOFF(SSB_SPROM11_PDOFFSET40MA) + i];
+
+	/* Power-per-rate region. Layout differs from rev 9: each 5 GHz
+	 * sub-band has four consecutive u32 entries (mcsbw20/40/80/160)
+	 * rather than two, and a pair of u16 (dot11agofdmhrbw202gpo,
+	 * ofdmlrbw202gpo) sits between the 2.4 GHz BW40 entry and the
+	 * 5 GHz BW20 entries.
+	 */
+	SPEX(cckbw202gpo,            SSB_SPROM11_CCKBW202GPO,            ~0, 0);
+	SPEX(cckbw20ul2gpo,          SSB_SPROM11_CCKBW20UL2GPO,          ~0, 0);
+	SPEX32(mcsbw202gpo,          SSB_SPROM11_MCSBW202GPO,            ~0, 0);
+	SPEX32(mcsbw402gpo,          SSB_SPROM11_MCSBW402GPO,            ~0, 0);
+	SPEX(dot11agofdmhrbw202gpo,  SSB_SPROM11_DOT11AGOFDMHRBW202GPO,  ~0, 0);
+	SPEX(ofdmlrbw202gpo,         SSB_SPROM11_OFDMLRBW202GPO,         ~0, 0);
+	SPEX32(mcsbw205glpo,         SSB_SPROM11_MCSBW205GLPO,           ~0, 0);
+	SPEX32(mcsbw405glpo,         SSB_SPROM11_MCSBW405GLPO,           ~0, 0);
+	SPEX32(mcsbw805glpo,         SSB_SPROM11_MCSBW805GLPO,           ~0, 0);
+	SPEX32(mcsbw1605glpo,        SSB_SPROM11_MCSBW1605GLPO,          ~0, 0);
+	SPEX32(mcsbw205gmpo,         SSB_SPROM11_MCSBW205GMPO,           ~0, 0);
+	SPEX32(mcsbw405gmpo,         SSB_SPROM11_MCSBW405GMPO,           ~0, 0);
+	SPEX32(mcsbw805gmpo,         SSB_SPROM11_MCSBW805GMPO,           ~0, 0);
+	SPEX32(mcsbw1605gmpo,        SSB_SPROM11_MCSBW1605GMPO,          ~0, 0);
+	SPEX32(mcsbw205ghpo,         SSB_SPROM11_MCSBW205GHPO,           ~0, 0);
+	SPEX32(mcsbw405ghpo,         SSB_SPROM11_MCSBW405GHPO,           ~0, 0);
+	SPEX32(mcsbw805ghpo,         SSB_SPROM11_MCSBW805GHPO,           ~0, 0);
+	SPEX32(mcsbw1605ghpo,        SSB_SPROM11_MCSBW1605GHPO,          ~0, 0);
+
+	/* TODO (region 0x190..0x1B0): mcslr5g{l,m,h}po, sb20in40{hr,lr}po,
+	 * sb20in80and160{hr,lr}5g{l,m,h}po, sb40and80{hr,lr}5g{l,m,h}po,
+	 * dot11agdup{hr,lr}po, pdoffset80ma[3]. Plus the femctrl context
+	 * block: femctrl, epagain{2g,5g}, pdgain{2g,5g}, tworangetssi
+	 * {2g,5g}, papdcap{2g,5g}, tssiposslope{2g,5g}, gainctrlsph,
+	 * pdoffset2g40ma[3], pdoffset2g40mvalid. Reachable via the
+	 * bcm47xx_sprom NVRAM fallback path.
+	 */
+
+	pr_info("bcma: SPROM rev 11 parsed: board=0x%04x rev=%u ccode=0x%04x txchain=0x%x rxchain=0x%x antswitch=%u subband5gver=%u\n",
+		bus->sprom.board_type, bus->sprom.board_rev,
+		bus->sprom.country_code,
+		bus->sprom.txchain, bus->sprom.rxchain, bus->sprom.antswitch,
+		bus->sprom.subband5gver);
+	for (i = 0; i < ARRAY_SIZE(r11_pwr_info_offset); i++) {
+		pr_info("bcma: SPROM r11 chain%d rxgains 2g={%u,%u,%u} 5gl={%u,%u,%u} 5gm={%u,%u,%u} 5gh={%u,%u,%u}\n",
+			i,
+			bus->sprom.rxgains_2g.elnagain[i],  bus->sprom.rxgains_2g.triso[i],  bus->sprom.rxgains_2g.trelnabyp[i],
+			bus->sprom.rxgains_5gl.elnagain[i], bus->sprom.rxgains_5gl.triso[i], bus->sprom.rxgains_5gl.trelnabyp[i],
+			bus->sprom.rxgains_5gm.elnagain[i], bus->sprom.rxgains_5gm.triso[i], bus->sprom.rxgains_5gm.trelnabyp[i],
+			bus->sprom.rxgains_5gh.elnagain[i], bus->sprom.rxgains_5gh.triso[i], bus->sprom.rxgains_5gh.trelnabyp[i]);
+	}
+}
+
 /*
  * Indicates the presence of external SPROM.
  */
@@ -640,7 +786,14 @@ int bcma_sprom_get(struct bcma_bus *bus)
 		bcma_warn(bus, "Invalid SPROM read from the PCIe card, trying to use fallback SPROM\n");
 		err = bcma_fill_sprom_with_fallback(bus, &bus->sprom);
 	} else {
-		bcma_sprom_extract_r8(bus, sprom);
+		switch (bus->sprom.revision) {
+		case 11:
+			bcma_sprom_extract_r11(bus, sprom);
+			break;
+		default:
+			bcma_sprom_extract_r8(bus, sprom);
+			break;
+		}
 		kfree(sprom);
 	}
 
diff --git a/drivers/firmware/broadcom/bcm47xx_sprom.c b/drivers/firmware/broadcom/bcm47xx_sprom.c
index bca03fd..00179ad 100644
--- a/drivers/firmware/broadcom/bcm47xx_sprom.c
+++ b/drivers/firmware/broadcom/bcm47xx_sprom.c
@@ -114,6 +114,52 @@ static void nvram_read_u32_2(const char *prefix, const char *name,
 	*val_hi = (val & 0xFFFF0000U) >> 16;
 }
 
+/*
+ * SROM rev 11 stores some per-chain values as comma-separated lists
+ * under a single NVRAM key (e.g. "pa5ga0=0xff4d,0x1690,..."). Parse
+ * such CSV payloads into a fixed-length destination array. Missing or
+ * unparseable elements leave the destination unchanged and emit one
+ * warning rather than aborting the whole read.
+ */
+#define NVRAM_READ_ARRAY(type)						\
+static void nvram_read_ ## type ## _array(const char *prefix,		\
+					  const char *postfix,		\
+					  const char *name,		\
+					  type *val, size_t len,	\
+					  bool fallback)		\
+{									\
+	char buf[256];							\
+	char *ptr, *next;						\
+	int err;							\
+	size_t i = 0;							\
+	type var;							\
+									\
+	err = get_nvram_var(prefix, postfix, name, buf, sizeof(buf),	\
+			    fallback);					\
+	if (err < 0)							\
+		return;							\
+	ptr = strim(buf);						\
+	while (ptr && *ptr && i < len) {				\
+		next = strchr(ptr, ',');				\
+		if (next)						\
+			*next++ = '\0';					\
+		err = kstrto ## type(ptr, 0, &var);			\
+		if (err) {						\
+			pr_warn("can not parse nvram %s%s entry %zu (%s): %d\n",	\
+				name, postfix ? postfix : "", i, ptr, err); \
+		} else {						\
+			val[i] = var;					\
+		}							\
+		i++;							\
+		ptr = next;						\
+	}								\
+}
+
+NVRAM_READ_ARRAY(u8)
+NVRAM_READ_ARRAY(u16)
+
+#undef NVRAM_READ_ARRAY
+
 static void nvram_read_leddc(const char *prefix, const char *name,
 			     u8 *leddc_on_time, u8 *leddc_off_time,
 			     bool fallback)
@@ -368,7 +414,6 @@ static void bcm47xx_sprom_fill_auto(struct ssb_sprom *sprom,
 	ENTRY(0x00000600, u16, pre, "legofdm40duppo", legofdm40duppo, 0, fb);
 	ENTRY(0x00000700, u8, pre, "pcieingress_war", pcieingress_war, 0, fb);
 
-	/* TODO: rev 11 support */
 	ENTRY(0x00000700, u8, pre, "rxgainerr2ga0", rxgainerr2ga[0], 0, fb);
 	ENTRY(0x00000700, u8, pre, "rxgainerr2ga1", rxgainerr2ga[1], 0, fb);
 	ENTRY(0x00000700, u8, pre, "rxgainerr2ga2", rxgainerr2ga[2], 0, fb);
@@ -388,7 +433,6 @@ static void bcm47xx_sprom_fill_auto(struct ssb_sprom *sprom,
 	ENTRY(0xfffffe00, u8, pre, "sar2g", sar2g, 0, fb);
 	ENTRY(0xfffffe00, u8, pre, "sar5g", sar5g, 0, fb);
 
-	/* TODO: rev 11 support */
 	ENTRY(0x00000700, u8, pre, "noiselvl2ga0", noiselvl2ga[0], 0, fb);
 	ENTRY(0x00000700, u8, pre, "noiselvl2ga1", noiselvl2ga[1], 0, fb);
 	ENTRY(0x00000700, u8, pre, "noiselvl2ga2", noiselvl2ga[2], 0, fb);
@@ -404,9 +448,132 @@ static void bcm47xx_sprom_fill_auto(struct ssb_sprom *sprom,
 	ENTRY(0x00000700, u8, pre, "noiselvl5gua0", noiselvl5gua[0], 0, fb);
 	ENTRY(0x00000700, u8, pre, "noiselvl5gua1", noiselvl5gua[1], 0, fb);
 	ENTRY(0x00000700, u8, pre, "noiselvl5gua2", noiselvl5gua[2], 0, fb);
+
+	/* SROM rev 11 globals. Per-chain rev-11 fields are read from
+	 * bcm47xx_fill_sprom_path_r11 (rev 11 packs them as CSV).
+	 */
+	ENTRY(0x00000800, u8,  pre, "subband5gver",   subband5gver,   0, fb);
+	ENTRY(0x00000800, u8,  pre, "femctrl",        femctrl,        0, fb);
+	ENTRY(0x00000800, u8,  pre, "epagain2g",      epagain2g,      0, fb);
+	ENTRY(0x00000800, u8,  pre, "epagain5g",      epagain5g,      0, fb);
+	ENTRY(0x00000800, u8,  pre, "pdgain2g",       pdgain2g,       0, fb);
+	ENTRY(0x00000800, u8,  pre, "pdgain5g",       pdgain5g,       0, fb);
+	ENTRY(0x00000800, u8,  pre, "tworangetssi2g", tworangetssi2g, 0, fb);
+	ENTRY(0x00000800, u8,  pre, "tworangetssi5g", tworangetssi5g, 0, fb);
+	ENTRY(0x00000800, u8,  pre, "papdcap2g",      papdcap2g,      0, fb);
+	ENTRY(0x00000800, u8,  pre, "papdcap5g",      papdcap5g,      0, fb);
+	ENTRY(0x00000800, u8,  pre, "tssiposslope2g", tssiposslope2g, 0, fb);
+	ENTRY(0x00000800, u8,  pre, "tssiposslope5g", tssiposslope5g, 0, fb);
+	ENTRY(0x00000800, u8,  pre, "gainctrlsph",    gainctrlsph,    0, fb);
+
+	ENTRY(0x00000800, u32, pre, "mcsbw802gpo",    mcsbw802gpo,    0, fb);
+	ENTRY(0x00000800, u32, pre, "mcsbw805glpo",   mcsbw805glpo,   0, fb);
+	ENTRY(0x00000800, u32, pre, "mcsbw805gmpo",   mcsbw805gmpo,   0, fb);
+	ENTRY(0x00000800, u32, pre, "mcsbw805ghpo",   mcsbw805ghpo,   0, fb);
+	ENTRY(0x00000800, u32, pre, "mcsbw1602gpo",   mcsbw1602gpo,   0, fb);
+	ENTRY(0x00000800, u32, pre, "mcsbw1605glpo",  mcsbw1605glpo,  0, fb);
+	ENTRY(0x00000800, u32, pre, "mcsbw1605gmpo",  mcsbw1605gmpo,  0, fb);
+	ENTRY(0x00000800, u32, pre, "mcsbw1605ghpo",  mcsbw1605ghpo,  0, fb);
+	ENTRY(0x00000800, u16, pre, "mcslr5glpo",     mcslr5glpo,     0, fb);
+	ENTRY(0x00000800, u16, pre, "mcslr5gmpo",     mcslr5gmpo,     0, fb);
+	ENTRY(0x00000800, u16, pre, "mcslr5ghpo",     mcslr5ghpo,     0, fb);
+
+	ENTRY(0x00000800, u16, pre, "sb20in40hrpo",            sb20in40hrpo,            0, fb);
+	ENTRY(0x00000800, u16, pre, "sb20in80and160hr5glpo",   sb20in80and160hr5glpo,   0, fb);
+	ENTRY(0x00000800, u16, pre, "sb20in80and160hr5gmpo",   sb20in80and160hr5gmpo,   0, fb);
+	ENTRY(0x00000800, u16, pre, "sb20in80and160hr5ghpo",   sb20in80and160hr5ghpo,   0, fb);
+	ENTRY(0x00000800, u16, pre, "sb40and80hr5glpo",        sb40and80hr5glpo,        0, fb);
+	ENTRY(0x00000800, u16, pre, "sb40and80hr5gmpo",        sb40and80hr5gmpo,        0, fb);
+	ENTRY(0x00000800, u16, pre, "sb40and80hr5ghpo",        sb40and80hr5ghpo,        0, fb);
+	ENTRY(0x00000800, u16, pre, "sb20in40lrpo",            sb20in40lrpo,            0, fb);
+	ENTRY(0x00000800, u16, pre, "sb20in80and160lr5glpo",   sb20in80and160lr5glpo,   0, fb);
+	ENTRY(0x00000800, u16, pre, "sb20in80and160lr5gmpo",   sb20in80and160lr5gmpo,   0, fb);
+	ENTRY(0x00000800, u16, pre, "sb20in80and160lr5ghpo",   sb20in80and160lr5ghpo,   0, fb);
+	ENTRY(0x00000800, u16, pre, "sb40and80lr5glpo",        sb40and80lr5glpo,        0, fb);
+	ENTRY(0x00000800, u16, pre, "sb40and80lr5gmpo",        sb40and80lr5gmpo,        0, fb);
+	ENTRY(0x00000800, u16, pre, "sb40and80lr5ghpo",        sb40and80lr5ghpo,        0, fb);
+	ENTRY(0x00000800, u16, pre, "dot11agduphrpo",          dot11agduphrpo,          0, fb);
+	ENTRY(0x00000800, u16, pre, "dot11agduplrpo",          dot11agduplrpo,          0, fb);
+
+	ENTRY(0x00000800, u8,  pre, "pdoffset2g40ma0",    pdoffset2g40ma[0],    0, fb);
+	ENTRY(0x00000800, u8,  pre, "pdoffset2g40ma1",    pdoffset2g40ma[1],    0, fb);
+	ENTRY(0x00000800, u8,  pre, "pdoffset2g40ma2",    pdoffset2g40ma[2],    0, fb);

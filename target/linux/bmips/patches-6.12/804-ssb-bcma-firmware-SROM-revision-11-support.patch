+/* SROM revision 11 offsets. Cross-referenced against Broadcom's
+ * bcmhd source (bcmsrom_tbl.h / bcmsrom.h).
+ *
+ * Five header fields are shifted past their rev-8 positions: IL0MAC,
+ * ANTAVAIL, TXRXC, CCODE, REGREV. The bitfield masks/shifts
+ * (SSB_SPROM8_ANTAVAIL_*, SSB_SPROM8_TXRXC_*) are reused unchanged: the
+ * field layout within each word is the same, only the absolute byte
+ * offset moved. boardrev (0x82) coincides between rev 8 and rev 11 and
+ * continues to be read from SSB_SPROM8_BOARDREV. CCODE is at 0x96 (per
+ * bcmsrom.h, word 75) because reusing SSB_SPROM8_CCODE = 0x92 collides
+ * with SROM11_MACMID (the middle u16 of the IL0MAC block at 0x90).
+ */
+#define SSB_SPROM11_IL0MAC		0x0090
+#define SSB_SPROM11_ANTAVAIL		0x00A0
+#define SSB_SPROM11_TXRXC		0x00A8
+#define SSB_SPROM11_CCODE		0x0096	/* word 75 */
+#define SSB_SPROM11_REGREV		0x0098	/* word 76, mask 0x00ff */
+
+#define SSB_SPROM11_SUBBAND5GVER	0x00D6	/* u8, low byte of u16 at word 107 */
+
+/* Per-chain pdoffset40ma triplet. */
+#define SSB_SPROM11_PDOFFSET40MA	0x00CA	/* 3 x u16, one per chain */
+
+/* Per-chain power info blocks. Stride 0x28 bytes (20 u16 words).
+ * Field layout within a block is given by SSB_SPROM11_PWR_* below. */
+#define SSB_SPROM11_PWR_INFO_CORE0	0x00D8
+#define SSB_SPROM11_PWR_INFO_CORE1	0x0100
+#define SSB_SPROM11_PWR_INFO_CORE2	0x0128
+
+/* Offsets relative to a per-chain power info block. */
+#define SSB_SPROM11_PWR_MAXP2GA		0x0000	/* u8, low byte of u16 */
+#define SSB_SPROM11_PWR_PA2GA		0x0002	/* 3 x u16, polynomial coeffs */
+#define SSB_SPROM11_PWR_RXGAINS0	0x0008	/* u16, sub-bands 5gm (lo) / 5gh (hi) packed */

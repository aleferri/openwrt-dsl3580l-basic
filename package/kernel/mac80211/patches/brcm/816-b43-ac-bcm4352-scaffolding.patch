+/**************************************************
+ * Basic PHY ops
+ **************************************************/
+
+/*
+ * prepare_structs is called by the b43 core after allocate() and before
+ * init(). Just zero the per-PHY struct: the HT-PHY mirror fields that
+ * needed seeding (tx_pwr_ctl = true, bb_mult_save = -1) are gone with
+ * their consumers (TX power control / TX-sample calibration are
+ * post-MVP — see ROADMAP §7r.5 note on est_pwr_lut and txpwrctrl).
+ */
+static void b43_phy_ac_op_prepare_structs(struct b43_wldev *dev)
+{
+	struct b43_phy_ac *phy_ac = dev->phy.ac;
+
+	memset(phy_ac, 0, sizeof(*phy_ac));
+}
+/*
+ * Mode-bit clears (phase 3 of op_init).
+ *
+ * Extracted from wlc_phy_init_acphy @0x53298 for chip 0x43b3 by
+ * reverse-tools/extract_init_acphy.py. The "generic" dispatch path
+ * (chipid ∉ {0x4352, 0x4360}) emits exactly four PHY writes; the
+ * BCM4352/BCM4360 path uses page 0x1xxx instead of 0x07xx for the
+ * trailing three. See reverse-output/by-chip/{43b3,4352}/
+ * init_acphy_extracted.c and reverse-output/by-chip/
+ * init_acphy_extracted_diff.md.
+ *
+ * The two RMW writes that embed chip-id (chip_id | 0x100/0x400 into
+ * 0x72a/0x725) are not statically extractable — left at hardware
+ * reset default for MVP.
+ */
+static void b43_phy_ac_mode_init(struct b43_wldev *dev)
+{
+	b43_phy_write(dev, 0x0410, 0x0077);  /* @0x0005331c */
+	b43_phy_write(dev, 0x0728, 0x0080);  /* @0x000534c0 */
+	b43_phy_write(dev, 0x0720, 0x0180);  /* @0x000534e8 */
+	b43_phy_write(dev, 0x0721, 0x5000);  /* @0x00053538 */
+}
